# dramacd-browser configuration
# Copy this file to `.env` and fill in the values you want to override.
# Everything is optional unless noted. The app starts with no .env at all.

# --- Server ---
# Port the FastAPI/Uvicorn server binds to.
DRAMACD_PORT=8080

# Folder that is scanned for drama-CD archives on first run. The UI lets you
# add/remove paths at runtime, so this is just a convenience default.
DRAMACD_SCAN_PATH=

# Optional API key. If set, mutating endpoints require it (header X-API-Key
# or ?api_key=...). Leave blank to allow unauthenticated local writes.
DRAMACD_API_KEY=

# Start with the pipeline (extraction / transcription / translation) enabled.
# 1 = on, 0 = off. You can also flip it in the sidebar at runtime.
DRAMACD_ENABLE_PIPELINE=0

# --- External binaries (Windows) ---
# Absolute paths to the executables. Required for transcription / rar/7z.
DRAMACD_FFMPEG_PATH=
DRAMACD_FFPROBE_PATH=
DRAMACD_7Z_PATH=

# --- DLsite scraping ---
# Optional HTTP or SOCKS proxy for DLsite requests, e.g.
#   http://proxy.example.com:8080
#   socks5://127.0.0.1:1080
DRAMACD_DLSITE_PROXY=

# --- Whisper ---
# Faster-Whisper model id. small / medium / large-v3 are common choices.
DRAMACD_WHISPER_MODEL=small
# auto / cuda / cpu
DRAMACD_WHISPER_DEVICE=auto

# --- Translation providers ---
# Each provider is optional; the UI lets you pick which one to use per job.
# Get a Gemini key at https://aistudio.google.com/apikey
DRAMACD_GEMINI_API_KEY=
DRAMACD_GEMINI_MODEL=gemini-2.0-flash

# Get an OpenRouter key at https://openrouter.ai/keys
DRAMACD_OPENROUTER_API_KEY=
DRAMACD_OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Chutes — https://chutes.ai
DRAMACD_CHUTES_API_KEY=
DRAMACD_CHUTES_MODEL=deepseek-ai/DeepSeek-V3.1

# Generic OpenAI-compatible endpoint (e.g. a self-hosted vLLM or LM Studio).
DRAMACD_OPENAI_COMPAT_API_KEY=
DRAMACD_OPENAI_COMPAT_BASE_URL=
DRAMACD_OPENAI_COMPAT_MODEL=
